{
  "name": "@lomio/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Command line interface for Lomio GenKit.",
  "type": "module",
  "bin": {
    "lomio": "./bin/lomio.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lomio": "node ./bin/lomio.js"
  }
}
