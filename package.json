{
  "name": "lomio-genkit",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI SaaS development framework for going from lomio create to a first AI result in under 5 minutes.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @lomio/web dev",
    "build": "pnpm -r --filter @lomio/* build",
    "typecheck": "pnpm -r --filter @lomio/* typecheck",
    "cli": "pnpm --filter @lomio/cli lomio"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3"
  }
}
